# ─── Server ─────────────────────────────────────────────────────────────────
PORT=5000

# Public URL of this Jukebar instance (if you need absolute links)
URL=http://localhost:5000

# Secret used to sign session cookies — change this to a long random string in production
SESSION_SECRET=change-me-to-something-random

# ─── Spotify ─────────────────────────────────────────────────────────────────
# Jukebar uses a long-lived refresh token only — no OAuth redirect in the server.
# Put the same redirect URL in the Spotify app dashboard only when you run a one-time
# script to exchange an auth code for SPOTIFY_REFRESH_TOKEN.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# Scopes your refresh token was authorized with (not read by the server — for setup only).
# When you run a one-time OAuth flow, request exactly these scopes (space-separated in the authorize URL).
SPOTIFY_SCOPES="user-read-private user-read-playback-state user-modify-playback-state user-read-currently-playing playlist-read-private playlist-read-collaborative playlist-modify-private playlist-modify-public"

# ─── Last.fm (optional, for track metadata) ──────────────────────────────────
LASTFM_API_KEY=

# ─── Dev / Debug ─────────────────────────────────────────────────────────────
# When "false", the Spotify background sync and diagnostics loop is disabled on startup
# Toggle at runtime via POST /api/spotify-background {"enabled": true/false} (any logged-in user; requires Spotify env)
SPOTIFY_BACKGROUND_API=true
